# Telegram Bot Configuration
TELEGRAM_BOT_TOKEN=your_bot_token_from_botfather
TELEGRAM_MODE=polling
# TELEGRAM_WEBHOOK_URL=https://your-domain.com/webhook
# TELEGRAM_WEBHOOK_PORT=3000
# TELEGRAM_ALLOWED_USER_IDS=123456789,987654321

# OpenCode Server Configuration
# Note: Password is optional. If you start opencode serve without OPENCODE_SERVER_PASSWORD,
# leave this empty or comment it out
OPENCODE_SERVER_URL=http://localhost:4096
OPENCODE_USERNAME=opencode
# OPENCODE_PASSWORD=your_secure_password  # Optional: only if you set OPENCODE_SERVER_PASSWORD
# OPENCODE_REQUEST_TIMEOUT=60000

# Session Configuration
# SESSION_STORAGE=file
# SESSION_FILE_PATH=./data/sessions.json
# SESSION_TTL=86400

# Application Configuration
# LOG_LEVEL=info
# MAX_MESSAGE_LENGTH=4000
# CODE_BLOCK_TIMEOUT=120000

# Path Configuration (for Docker/OrbStack deployment)
# 工作目录 - 你的代码项目路径 (必需)
WORKSPACE_PATH=/path/to/your/project

# OpenCode 配置路径 (可选，默认 ~/.config/opencode)
CONFIG_PATH=~/.config/opencode

# OpenCode Session 数据路径 (可选，默认 ~/.local/share/opencode)
# 共享此路径可以让容器内的 opencode serve 访问主机已有的 sessions
DATA_PATH=~/.local/share/opencode
