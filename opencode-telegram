#!/bin/bash
#
# OpenCode Telegram Plugin - Universal Entry Point
# Usage: opencode-telegram [command]
#
# This script can be run from anywhere and will:
# 1. Auto-detect the plugin installation directory
# 2. Delegate to appropriate sub-scripts
# 3. Support both local and global installations

set -e

# Script metadata
readonly SCRIPT_NAME="opencode-telegram"
readonly SCRIPT_VERSION="1.0.0"

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
NC='\033[0m'

# Get the directory where this script is located
get_script_dir() {
    local script_path="$0"
    
    # Handle symlinks
    while [ -L "$script_path" ]; do
        local dir="$(dirname "$script_path")"
        script_path="$(readlink "$script_path")"
        # If relative symlink, resolve relative to dir
        [[ "$script_path" = /* ]] || script_path="$dir/$script_path"
    done
    
    dirname "$script_path"
}

# Find plugin directory
find_plugin_dir() {
    local script_dir
    script_dir="$(get_script_dir)"
    
    # If we're in the plugin directory, use it
    if [ -f "$script_dir/control.sh" ] && [ -f "$script_dir/package.json" ]; then
        echo "$script_dir"
        return 0
    fi
    
    # Check parent directory (in case script is in bin/)
    if [ -f "$script_dir/../control.sh" ] && [ -f "$script_dir/../package.json" ]; then
        echo "$script_dir/.."
        return 0
    fi
    
    # Check environment variable
    if [ -n "$OPENCODE_TELEGRAM_DIR" ] && [ -f "$OPENCODE_TELEGRAM_DIR/control.sh" ]; then
        echo "$OPENCODE_TELEGRAM_DIR"
        return 0
    fi
    
    # Check common installation paths
    local common_paths=(
        "$HOME/.config/agent-toolkits/opencode-telegram-plugin"
        "/usr/local/share/opencode-telegram-plugin"
        "/opt/opencode-telegram-plugin"
        "$HOME/opencode-telegram-plugin"
    )
    
    for path in "${common_paths[@]}"; do
        if [ -f "$path/control.sh" ]; then
            echo "$path"
            return 0
        fi
    done
    
    return 1
}

# Main plugin directory
PLUGIN_DIR=""

# Initialize
init() {
    PLUGIN_DIR="$(find_plugin_dir)"
    
    if [ -z "$PLUGIN_DIR" ]; then
        echo -e "${RED}Error: Cannot find OpenCode Telegram Plugin installation${NC}" >&2
        echo ""
        echo "Please ensure the plugin is installed and one of the following is true:"
        echo "  1. Run this script from the plugin directory"
        echo "  2. Set OPENCODE_TELEGRAM_DIR environment variable"
        echo "  3. Install to a standard location (~/.config/agent-toolkits, /usr/local/share, etc.)"
        exit 1
    fi
    
    # Convert to absolute path
    PLUGIN_DIR="$(cd "$PLUGIN_DIR" && pwd)"
}

# Print header
print_header() {
    echo -e "${BLUE}"
    echo "╔════════════════════════════════════════════════════════╗"
    echo "║     OpenCode Telegram Plugin v${SCRIPT_VERSION}              ║"
    echo "╚════════════════════════════════════════════════════════╝"
    echo -e "${NC}"
}

# Print status
print_status() {
    echo -e "${CYAN}Plugin Directory:${NC} $PLUGIN_DIR"
    echo ""
}

# Delegate to control.sh
delegate_control() {
    local cmd="$1"
    shift
    
    case "$cmd" in
        host|docker|start|status|stop|logs|restart|shell|update|pair|whitelist|setup)
            cd "$PLUGIN_DIR"
            exec ./control.sh "$cmd" "$@"
            ;;
        *)
            echo -e "${RED}Unknown command: $cmd${NC}" >&2
            show_help
            exit 1
            ;;
    esac
}

# Quick start wizard
cmd_quickstart() {
    print_header
    print_status
    
    echo -e "${GREEN}Welcome to OpenCode Telegram Plugin!${NC}"
    echo ""
    
    # Check if configured
    if [ ! -f "$PLUGIN_DIR/.env" ]; then
        echo "🔧 First time setup detected."
        echo ""
        read -p "Run setup now? (Y/n): " run_setup
        if [[ ! "$run_setup" =~ ^[Nn]$ ]]; then
            cd "$PLUGIN_DIR"
            exec ./control.sh setup
        fi
    else
        echo "✓ Configuration found"
        echo ""
        
        # Show current config (without secrets)
        source "$PLUGIN_DIR/.env" 2>/dev/null || true
        echo -e "${CYAN}Current Configuration:${NC}"
        echo "  Workspace: ${WORKSPACE_PATH:-Not set}"
        echo "  Mode: ${TELEGRAM_MODE:-polling}"
        echo ""
        
        # Show quick actions
        echo "Quick Actions:"
        echo "  1. Start locally      : $SCRIPT_NAME host"
        echo "  2. Start with Docker  : $SCRIPT_NAME docker"
        echo "  3. Generate pair code : $SCRIPT_NAME pair"
        echo "  4. Check status       : $SCRIPT_NAME status"
        echo ""
        
        read -p "What would you like to do? (1-4, or 'q' to quit): " action
        case "$action" in
            1) exec "$0" host ;;
            2) exec "$0" docker ;;
            3) exec "$0" pair ;;
            4) exec "$0" status ;;
            q|Q) exit 0 ;;
            *) echo "Invalid option"; exit 1 ;;
        esac
    fi
}

# Doctor command - diagnose issues
cmd_doctor() {
    print_header
    print_status
    
    echo "🔍 Running diagnostics..."
    echo ""
    
    local issues=0
    
    # Check Node.js
    if command -v node &> /dev/null; then
        local node_version
        node_version="$(node --version)"
        echo -e "${GREEN}✓${NC} Node.js: $node_version"
    else
        echo -e "${RED}✗${NC} Node.js: Not found"
        ((issues++))
    fi
    
    # Check npm
    if command -v npm &> /dev/null; then
        echo -e "${GREEN}✓${NC} npm: $(npm --version)"
    else
        echo -e "${RED}✗${NC} npm: Not found"
        ((issues++))
    fi
    
    # Check OpenCode
    if command -v opencode &> /dev/null; then
        echo -e "${GREEN}✓${NC} opencode: Installed"
    else
        echo -e "${YELLOW}⚠${NC} opencode: Not found (required for host mode)"
    fi
    
    # Check Docker
    if command -v docker &> /dev/null; then
        echo -e "${GREEN}✓${NC} Docker: Installed"
    else
        echo -e "${YELLOW}⚠${NC} Docker: Not found (required for docker mode)"
    fi
    
    # Check configuration
    if [ -f "$PLUGIN_DIR/.env" ]; then
        echo -e "${GREEN}✓${NC} Configuration: Found"
        
        # Validate critical fields
        source "$PLUGIN_DIR/.env" 2>/dev/null || true
        
        if [ -n "$TELEGRAM_BOT_TOKEN" ]; then
            echo -e "${GREEN}✓${NC} Bot Token: Configured"
        else
            echo -e "${RED}✗${NC} Bot Token: Missing"
            ((issues++))
        fi
        
        if [ -n "$WORKSPACE_PATH" ]; then
            if [ -d "$WORKSPACE_PATH" ]; then
                echo -e "${GREEN}✓${NC} Workspace: $WORKSPACE_PATH"
            else
                echo -e "${YELLOW}⚠${NC} Workspace: Not found ($WORKSPACE_PATH)"
            fi
        else
            echo -e "${YELLOW}⚠${NC} Workspace: Not configured"
        fi
    else
        echo -e "${RED}✗${NC} Configuration: Not found"
        echo "   Run: $SCRIPT_NAME setup"
        ((issues++))
    fi
    
    # Check build
    if [ -f "$PLUGIN_DIR/dist/standalone.js" ]; then
        echo -e "${GREEN}✓${NC} Build: Compiled"
    else
        echo -e "${YELLOW}⚠${NC} Build: Not compiled"
        echo "   Run: cd $PLUGIN_DIR && npm run build"
    fi
    
    echo ""
    if [ $issues -eq 0 ]; then
        echo -e "${GREEN}All checks passed!${NC}"
        echo "Ready to start with: $SCRIPT_NAME host"
    else
        echo -e "${YELLOW}Found $issues issue(s). Please fix before starting.${NC}"
        exit 1
    fi
}

# Show version
cmd_version() {
    echo "$SCRIPT_NAME version $SCRIPT_VERSION"
    echo "Plugin directory: $PLUGIN_DIR"
}

# Show help
show_help() {
    print_header
    
    echo "Universal entry point for OpenCode Telegram Plugin"
    echo ""
    echo "Usage: $SCRIPT_NAME [command] [options]"
    echo ""
    echo "Core Commands:"
    echo "  quickstart    Interactive setup wizard (default)"
    echo "  setup         Configure the plugin"
    echo "  host          Start in host mode"
    echo "  docker        Start with Docker"
    echo "  status        Check service status"
    echo "  stop          Stop services"
    echo "  pair          Generate pairing code"
    echo "  whitelist     Manage whitelist"
    echo ""
    echo "Utility Commands:"
    echo "  doctor        Diagnose installation issues"
    echo "  version       Show version info"
    echo "  help          Show this help"
    echo ""
    echo "Examples:"
    echo "  $SCRIPT_NAME                    # Run quickstart wizard"
    echo "  $SCRIPT_NAME setup              # Configure"
    echo "  $SCRIPT_NAME host               # Start locally"
    echo "  $SCRIPT_NAME pair               # Generate pairing code"
    echo "  $SCRIPT_NAME doctor             # Check installation"
    echo ""
    echo "Environment Variables:"
    echo "  OPENCODE_TELEGRAM_DIR    Override plugin directory"
}

# Main
main() {
    init
    
    local cmd="${1:-quickstart}"
    shift || true
    
    case "$cmd" in
        quickstart|"")
            cmd_quickstart
            ;;
        doctor|check)
            cmd_doctor
            ;;
        version|-v|--version)
            cmd_version
            ;;
        help|-h|--help)
            show_help
            ;;
        host|docker|start|status|stop|logs|restart|shell|update|pair|whitelist|setup)
            delegate_control "$cmd" "$@"
            ;;
        *)
            echo -e "${RED}Unknown command: $cmd${NC}" >&2
            echo ""
            show_help
            exit 1
            ;;
    esac
}

main "$@"
